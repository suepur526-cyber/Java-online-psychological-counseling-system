#!/bin/sh
BASE_DIR="$(cd "$(dirname "$0")" && pwd)"
MAVEN_VERSION=3.9.9
MAVEN_DIR="$BASE_DIR/.mvn/apache-maven-$MAVEN_VERSION"
MAVEN_ZIP="$BASE_DIR/.mvn/apache-maven-$MAVEN_VERSION-bin.zip"
if [ ! -x "$MAVEN_DIR/bin/mvn" ]; then
  echo "Downloading Apache Maven $MAVEN_VERSION..."
  curl -L "https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/$MAVEN_VERSION/apache-maven-$MAVEN_VERSION-bin.zip" -o "$MAVEN_ZIP"
  unzip -q "$MAVEN_ZIP" -d "$BASE_DIR/.mvn"
fi
"$MAVEN_DIR/bin/mvn" "$@"
